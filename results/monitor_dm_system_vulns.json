cwe":"CWE-863","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["15.5.16"],"state":"fixed","available":[{"version":"15.5.16","date":"2026-05-11","kind":"first-observed"}]},"advisories":[],"risk":0.26325000000000004},"relatedVulnerabilities":[{"id":"CVE-2026-44573","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-44573","namespace":"nvd:cpe","severity":"High","urls":["https://github.com/vercel/next.js/security/advisories/GHSA-36qx-fr4f-26g5"],"description":"Next.js is a React framework for building full-stack web applications. From 12.2.0 to before 15.5.16 and 16.2.5, Applications using the Pages Router with i18n configured and middleware/proxy-based authorization can allow unauthorized access to protected page data through locale-less /_next/data/<buildId>/<page>.json requests. In affected configurations, middleware does not run for the unprefixed data route, allowing an attacker to retrieve SSR JSON for protected pages without passing the intended authorization checks. This vulnerability is fixed in 15.5.16 and 16.2.5.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:N/A:N","metrics":{"baseScore":7.5,"exploitabilityScore":3.9,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-44573","epss":0.00351,"percentile":0.2683,"date":"2026-06-20"}],"cwes":[{"cve":"CVE-2026-44573","cwe":"CWE-863","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"next","version":"15.5.14"}},"found":{"vulnerabilityID":"GHSA-36qx-fr4f-26g5","versionConstraint":">=12.2.0,<15.5.16 (semantic)"},"fix":{"suggestedVersion":"15.5.16"}}],"artifact":{"id":"306692ada470f89a","name":"next","version":"15.5.14","type":"npm","locations":[{"path":"/packages/ui/frontend/package-lock.jso