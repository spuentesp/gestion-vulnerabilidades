TML `<style>` tags, `</style>` in CSS values breaks out of the style context, enabling XSS. Version 8.5.10 fixes the issue.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:C/C:L/I:L/A:N","metrics":{"baseScore":6.1,"exploitabilityScore":2.9,"impactScore":2.8},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-41305","epss":0.00194,"percentile":0.09156,"date":"2026-06-20"}],"cwes":[{"cve":"CVE-2026-41305","cwe":"CWE-79","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"postcss","version":"8.4.31"}},"found":{"vulnerabilityID":"GHSA-qx2v-qp2m-jg93","versionConstraint":"<8.5.10 (semantic)"},"fix":{"suggestedVersion":"8.5.10"}}],"artifact":{"id":"607e226359e6feae","name":"postcss","version":"8.4.31","type":"npm","locations":[{"path":"/packages/ui/frontend/package-lock.json","accessPath":"/packages/ui/frontend/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:postcss:postcss:8.4.31:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/postcss@8.4.31","upstreams":[]}},{"vulnerability":{"id":"GHSA-vfv6-92ff-j949","dataSource":"https://github.com/advisories/GHSA-vfv6-92ff-j949","namespace":"github:language:javascript","severity":"Low","urls":["https://github.com/vercel/next.js/security/advisories/GHSA-vfv6-92ff-j949","https://github.com/vercel/next.js/releases/tag/v15.5.16","https://github.com/vercel/next.js/releases/tag/v16.2.5","https://nvd.nist.gov/vuln/detail/CVE-2026-44582"],"description":"Next.js vulnerable to cache poisoning via collisions in React Server Component cache-busting","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:N/I:L/A:N","metrics":{"baseScore":3.7,"exploitabilityScore":2.3,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-44582","epss":0.00203,"percentile":0.10274,"date":"2026-06-20"}],"cwes":[{"cve":"CVE-2026-44582","cwe":"CWE-328","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["15.5.16"],"state":"fixed","available":[{"version":"15.5.16","date":"2026-05-11","kind":"first-observed"}]},"advisories":[],"risk":0.068005},"relatedVulnerabilities":[{"id":"CVE-2026-44582","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-44582","namespace":"nvd:cpe","severity":"Low","urls":["https://github.com/vercel/next.js/security/advisories/GHSA-vfv6-92ff-j949"],"description":"Next.js is a React framework for building full-stack web applications. From 13.4.6 to before 15.5.16 and 16.2.5, React Server Component responses can be vulnerable to cache poisoning in deployments that rely on shared caches with insufficient response partitioning. In affected conditions, collisions in the _rsc cache-busting value can allow an attacker to poison cache entries so users receive the wrong response variant for a given URL. This vulnerability is fixed in 15.5.16 and 16.2.5.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:N/I:L/A:N","metrics":{"baseScore":3.7,"exploitabilityScore":2.3,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-44582","epss":0.00203,"percentile":0.10274,"date":"2026-06-20"}],"cwes":[{"cve":"CVE-2026-44582","cwe":"CWE-328","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"next","version":"15.5.14"}},"found":{"vulnerabilityID":"GHSA-vfv6-92ff-j949","versionConstraint":">=13.4.6,<15.5.16 (semantic)"},"fix":{"suggestedVersion":"15.5.16"}}],"artifact":{"id":"306692ada470f89a","name":"next","version":"15.5.14","type":"npm","locations":[{"path":"/packages/ui/frontend/package-lock.json","accessPath":"/packages/ui/frontend/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:vercel:next.js:15.5.14:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/next@15.5.14","upstreams":[]}},{"vulnerability":{"id":"GHSA-3g8h-86w9-wvmq","dataSource":"https://github.com/advisories/GHSA-3g8h-86w9-wvmq","namespace":"github:language:javascript","severity":"Low","urls":["https://github.com/vercel/next.js/security/advisories/GHSA-3g8h-86w9-wvmq","https://github.com/vercel/next.js/releases/tag/v15.5.16","https://github.com/vercel/next.js/releases/tag/v16.2.5","https://nvd.nist.gov/vuln/detail/CVE-2026-44572"],"description":"Next.js's Middleware / Proxy redirects can be cache-poisoned","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":3.7,"exploitabilityScore":2.3,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-44572","epss":0.00195,"percentile":0.09324,"date":"2026-06-20"}],"cwes":[{"cve":"CVE-2026-44572","cwe":"CWE-349","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["15.5.16"],"state":"fixed","available":[{"version":"15.5.16","date":"2026-05-11","kind":"first-observed"}]},"advisories":[],"risk":0.06532499999999998},"relatedVulnerabilities":[{"id":"CVE-2026-44572","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-44572","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/vercel/next.js/security/advisories/GHSA-3g8h-86w9-wvmq"],"description":"Next.js is a React framework for building full-stack web applications. From 12.2.0 to before 15.5.16 and 16.2.5, an external client could send a x-nextjs-data header on a normal request to a path handled by middleware that returns a redirect. When that happened, the middleware/proxy could treat the request as a data request and replace the standard Location redirect header with the internal x-nextjs-redirect header. Browsers do not follow x-nextjs-redirect, so the response became an unusable redirect for normal clients. If the application was deployed behind a CDN or reverse proxy that caches 3xx responses without varying on this header, a single attacker request could poison the cached redirect response for the affected path. Subsequent visitors could then receive a cached redirect response without a Location header, causing a denial of service for that redirect path until the cache entry expired or was purged. This vulnerability is fixed in 15.5.16 and 16.2.5.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":5.9,"exploitabilityScore":2.3,"impactScore":3.6},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":3.7,"exploitabilityScore":2.3,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-44572","epss":0.00195,"percentile":0.09324,"date":"2026-06-20"}],"cwes":[{"cve":"CVE-2026-44572","cwe":"CWE-349","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"next","version":"15.5.14"}},"found":{"vulnerabilityID":"GHSA-3g8h-86w9-wvmq","versionConstraint":">=12.2.0,<15.5.16 (semantic)"},"fix":{"suggestedVersion":"15.5.16"}}],"artifact":{"id":"306692ada470f89a","name":"next","version":"15.5.14","type":"npm","locations":[{"path":"/packages/ui/frontend/package-lock.json","accessPath":"/packages/ui/frontend/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:vercel:next.js:15.5.14:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/next@15.5.14","upstreams":[]}},{"vulnerability":{"id":"GHSA-8h