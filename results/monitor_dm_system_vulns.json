nfiguration (by default, all patterns are allowed). This vulnerability is fixed in 15.5.16 and 16.2.5.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:U/C:N/I:N/A:H","metrics":{"baseScore":5.9,"exploitabilityScore":2.3,"impactScore":3.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-44577","epss":0.00395,"percentile":0.31167,"date":"2026-06-20"}],"cwes":[{"cve":"CVE-2026-44577","cwe":"CWE-770","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"next","version":"15.5.14"}},"found":{"vulnerabilityID":"GHSA-h64f-5h5j-jqjh","versionConstraint":">=10.0.0,<15.5.16 (semantic)"},"fix":{"suggestedVersion":"15.5.16"}}],"artifact":{"id":"306692ada470f89a","name":"next","version":"15.5.14","type":"npm","locations":[{"path":"/packages/ui/frontend/package-lock.json","accessPath":"/packages/ui/frontend/package-lock.json","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":["MIT"],"cpes":["cpe:2.3:a:vercel:next.js:15.5.14:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/next@15.5.14","upstreams":[]}},{"vulnerability":{"id":"GHSA-wfc6-r584-vfw7","dataSource":"https://github.com/advisories/GHSA-wfc6-r584-vfw7","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/vercel/next.js/security/advisories/GHSA-wfc6-r584-vfw7","https://github.com/vercel/next.js/releases/tag/v15.5.16","https://github.com/vercel/next.js/releases/tag/v16.2.5","https://nvd.nist.gov/vuln/detail/CVE-2026-44576"],"description":"Next.js vulnerable to cache poisoning in React Server Component responses","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:C/C:N/I:L/A:L","metrics":{"baseScore":5.4,"exploitabilityScore":2.3,"impactScore":2.8},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-44576","epss":0.00241,"percentile":0.14972,"date":"2026-06-20"}],"cwes":[{"cve":"CVE-2026-44576","cwe":"CWE-436","source":"security-advisories@github.com","type":"Secondary"}],"fix":{"versions":["15.5.16"],"state":"fixed","available":[{"version":"15.5.16","date":"2026-05-11","kind":"first-observed"}]},"advisories":[],"risk":0.12532},"relatedVulnerabilities":[{"id":"CVE-2026-44576","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-44576","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/vercel/next.js/security/advisories/GHSA-wfc6-r584-vfw7"],"description":"Next.js is a React framework for building full-stack web applications. From 14.2.0 to before 15.5.16 and 16.2.5, applications using React Server Components can be vulnerable to cache poisoning when shared caches do not correctly partition response variants. Under affected conditions, an attacker can cause an RSC response to be served from the original URL and poison shared cache entries so later visitors receive component payloads instead of the expected HTML. This vulnerability is fixed in 15.5.16 and 16.2.5.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:N/UI:N/S:C/C:N/I:L/A:L","metrics":{"baseScore":5.4,"exploitabilityScore":2.3,"impactScore":2.8},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-44576","epss":0.00241,"percentile":0.14972,"date":"2026-06-20"}],"cwes":[{"cve":"CVE-2026-44576","cwe":"CWE-436","source":"security-advisories@github.com","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"next","version":"15.5.14"}},"found":{"vulnerabilityID":"GHSA-wfc6-r584-vfw7","versionConstraint":">=14.2.0,<15.5.16 (semantic)"},"fix":{"suggestedVersion":"15.5.16"}}],"artifact":{"id":"306692ada470f89a","name":"next","version":"15.5.14","type":"npm","locations":[{"path":